BIOWATCH_ENVIRONMENT=local
BIOWATCH_DATABASE_URL=postgresql+asyncpg://biowatch:biowatch@localhost:55432/biowatch
BIOWATCH_REDIS_URL=redis://localhost:56379/0
BIOWATCH_ELASTICSEARCH_URL=http://localhost:59200
BIOWATCH_ELASTICSEARCH_INDEX=biowatch-papers
BIOWATCH_ELASTICSEARCH_TIMEOUT_SECONDS=10.0
BIOWATCH_EUROPE_PMC_TIMEOUT_SECONDS=10.0
BIOWATCH_EUROPE_PMC_MAX_ATTEMPTS=3
BIOWATCH_EUROPE_PMC_RETRY_BACKOFF_SECONDS=0.25
BIOWATCH_WORKER_METRICS_PORT=9100
BIOWATCH_SCHEDULER_INTERVAL_SECONDS=60
BIOWATCH_TELEGRAM_BOT_TOKEN=
BIOWATCH_LLM_PROVIDER=openai
BIOWATCH_LLM_API_KEY=
BIOWATCH_LLM_MODEL=gpt-5-mini
BIOWATCH_LLM_TIMEOUT_SECONDS=20.0
BIOWATCH_SUMMARY_PROMPT_VERSION=v1
BIOWATCH_SUMMARY_WAIT_TIMEOUT_SECONDS=15.0
BIOWATCH_DELIVERY_PREPARE_OFFSET_MINUTES=30
BIOWATCH_DELIVERY_PREPARE_SUMMARY_TIMEOUT_SECONDS=1500.0
